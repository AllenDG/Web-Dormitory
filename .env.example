# ============================================
# DORMITORY PLATFORM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Environment
VITE_ENV=development
VITE_APP_NAME=Dormitory Platform
VITE_APP_VERSION=6.0.0

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_AI_CHATBOT=true
VITE_ENABLE_AI_RECOMMENDATIONS=true
VITE_ENABLE_AI_SEARCH_PARSER=true

# AI Configuration (Anthropic Claude)
# Get your API key from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_api_key_here
VITE_AI_MODEL=claude-3-5-sonnet-20241022
VITE_AI_MAX_TOKENS=1024
VITE_AI_TEMPERATURE=0.7

# Use Mock AI (set to false when backend is ready)
VITE_USE_MOCK_AI=true

# Map Configuration (Mapbox)
# Get your token from: https://www.mapbox.com/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_ENABLE_ANALYTICS=false

# Debug
VITE_DEBUG_MODE=false
VITE_SHOW_DEV_TOOLS=true
